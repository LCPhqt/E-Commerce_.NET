@page
@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center" style="max-width:480px;margin:0 auto;">
        <div style="background:rgba(255,255,255,0.55);backdrop-filter:blur(18px) saturate(1.6);-webkit-backdrop-filter:blur(18px) saturate(1.6);border:1px solid rgba(255,255,255,0.45);border-radius:20px;padding:3rem 2rem;box-shadow:0 8px 32px rgba(0,0,0,0.04);">
            <div style="font-size:3.5rem;margin-bottom:1rem;color:#fca5a5;">
                <i class="bi bi-shield-exclamation"></i>
            </div>
            <h1 style="font-family:'Outfit',sans-serif;font-weight:650;font-size:2rem;letter-spacing:-0.03em;color:#1a1a2e;margin-bottom:0.5rem;">403</h1>
            <h3 style="font-family:'Outfit',sans-serif;font-weight:500;color:#1a1a2e;margin-bottom:0.75rem;">Truy cập bị từ chối</h3>
            <p style="color:#6b7280;margin-bottom:1.5rem;">Bạn không có quyền truy cập trang này.</p>
            <a href="/"
               style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.82rem;font-weight:550;padding:0.75rem 1.75rem;border:none;border-radius:10px;background:linear-gradient(135deg,#6366f1,#a855f7);color:white;text-decoration:none;box-shadow:0 4px 16px rgba(99,102,241,0.25);transition:all 0.3s;">
                <i class="bi bi-house"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>
