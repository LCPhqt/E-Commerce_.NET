@using ECommerceFinalProject.Services
@inject ICartService CartService
@{
    var cartCount = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var cart = await CartService.GetCartAsync(User.Identity.Name!);
        cartCount = cart?.CartItems?.Sum(ci => ci.SoLuong) ?? 0;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ECommerce</title>

    <!-- Google Fonts: Outfit only — clean, modern, versatile -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;450;500;550;600;650;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/customer.css" rel="stylesheet" />
</head>
<body>
    <!-- Liquid Glass Navbar -->
    <nav class="navbar navbar-expand-lg navbar-glass sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="/Customer/Home">
                ECommerce
                <small>Cửa hàng công nghệ</small>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Customer/Home"><i class="bi bi-house-door"></i> Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Customer/Products"><i class="bi bi-grid"></i> Sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/Customer/Cart">
                            <i class="bi bi-cart3"></i> Giỏ hàng
                            @if (cartCount > 0)
                            {
                                <span class="cart-badge">@cartCount</span>
                            }
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Customer/Orders"><i class="bi bi-clock-history"></i> Đơn hàng</a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @User.FindFirst("FullName")?.Value
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="/Customer/Orders"><i class="bi bi-clock-history"></i> Đơn hàng</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Admin/Dashboard"><i class="bi bi-shield-lock"></i> Trang Admin</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container py-3">
                <div class="alert-glass success animate-fade-in">@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container py-3">
                <div class="alert-glass error animate-fade-in">@TempData["ErrorMessage"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <!-- Liquid Glass Footer -->
    <footer class="footer-glass">
        <div class="footer-accent"></div>
        <div class="container">
            <div class="row footer-top g-4">
                <div class="col-lg-4">
                    <span class="footer-brand">ECommerce</span>
                    <p class="footer-tagline">Cửa hàng công nghệ cao cấp — trải nghiệm mua sắm tinh tế, hiện đại.</p>
                </div>
                <div class="col-6 col-lg-4">
                    <h6 class="footer-heading">Khám phá</h6>
                    <ul class="footer-links">
                        <li><a href="/Customer/Home">Trang chủ</a></li>
                        <li><a href="/Customer/Products">Sản phẩm</a></li>
                        <li><a href="/Customer/Cart">Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-4">
                    <h6 class="footer-heading">Tài khoản</h6>
                    <ul class="footer-links">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a href="/Customer/Orders">Đơn hàng của tôi</a></li>
                            <li><a href="/Account/Logout">Đăng xuất</a></li>
                        }
                        else
                        {
                            <li><a href="/Account/Login">Đăng nhập</a></li>
                            <li><a href="/Account/Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-copy">&copy; 2026 ECommerce. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Image fallback
        function fallbackImg(el) {
            el.onerror = null;
            el.style.display = 'none';
            var placeholder = document.createElement('div');
            placeholder.className = 'card-img-placeholder';
            placeholder.innerHTML = '<i class="bi bi-image"></i>';
            el.parentElement.insertBefore(placeholder, el.nextSibling);
        }

        // Navbar scroll shadow
        document.addEventListener('DOMContentLoaded', function() {
            var nav = document.getElementById('mainNav');
            window.addEventListener('scroll', function() {
                if (window.scrollY > 10) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            }, { passive: true });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
