@using ECommerceFinalProject.Services
@inject ICartService CartService
@{
    var cartCount = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var cart = await CartService.GetCartAsync(User.Identity.Name!);
        cartCount = cart?.CartItems?.Sum(ci => ci.SoLuong) ?? 0;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ECommerce</title>

    <!-- Google Fonts: Bodoni Moda + Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;0,6..96,700;1,6..96,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/customer.css" rel="stylesheet" />
</head>
<body>
    <!-- Editorial Navbar -->
    <nav class="navbar navbar-expand-lg navbar-editorial sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/Customer/Home">
                ECommerce
                <small>Cửa hàng công nghệ</small>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Customer/Home"><i class="bi bi-house-door"></i> Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Customer/Products"><i class="bi bi-grid"></i> Sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/Customer/Cart">
                            <i class="bi bi-cart"></i> Giỏ hàng
                            @if (cartCount > 0)
                            {
                                <span class="cart-badge">@cartCount</span>
                            }
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Customer/Orders"><i class="bi bi-clock-history"></i> Đơn hàng</a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.FindFirst("FullName")?.Value
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Customer/Orders"><i class="bi bi-clock-history"></i> Đơn hàng</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Admin/Dashboard"><i class="bi bi-shield-lock"></i> Trang Admin</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container py-3">
                <div class="alert-editorial success">@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container py-3">
                <div class="alert-editorial error">@TempData["ErrorMessage"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer-editorial">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="footer-brand">ECommerce</span>
                    <p class="mb-0 mt-1">Đồ án cuối kỳ — ASP.NET Core Razor Pages</p>
                </div>
                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                    <p class="mb-0">&copy; 2026 ECommerce</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Image fallback
        function fallbackImg(el) {
            el.onerror = null;
            el.style.display = 'none';
            var placeholder = document.createElement('div');
            placeholder.className = 'card-img-top d-flex align-items-center justify-content-center bg-light text-muted';
            placeholder.style.minHeight = '260px';
            placeholder.innerHTML = '<i class="bi bi-image" style="font-size: 48px;"></i>';
            el.parentElement.insertBefore(placeholder, el.nextSibling);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
