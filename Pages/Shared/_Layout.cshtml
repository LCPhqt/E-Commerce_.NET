<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerce</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">🛒 ECommerce</a>
            <div class="ml-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text text-white me-3">Xin chào, @User.Identity.Name</span>
                    <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Đăng xuất</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-outline-light btn-sm me-2">Đăng nhập</a>
                    <a href="/Account/Register" class="btn btn-light btn-sm">Đăng ký</a>
                }
            </div>
        </div>
    </nav>
    <main>
        @RenderBody()
    </main>
</body>
</html>
