<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ECommerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,400;6..96,500;6..96,600;6..96,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body style="background:#f5f3ef;font-family:'Outfit',sans-serif;">
    <nav style="background:#fff;border-bottom:1px solid #e8e5e0;padding:0.75rem 0;">
        <div style="max-width:1280px;margin:0 auto;padding:0 1rem;display:flex;align-items:center;justify-content:space-between;">
            <a href="/" style="font-family:'Bodoni Moda',Georgia,serif;font-size:1.3rem;font-weight:600;color:#1a1a1a;text-decoration:none;">ECommerce</a>
            <div style="display:flex;gap:0.75rem;align-items:center;">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard" style="font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.4rem 0.85rem;border:1px solid #e8e5e0;border-radius:2px;color:#1a1a1a;text-decoration:none;">🔑 Admin</a>
                    }
                    <span style="font-size:0.85rem;color:#6b6560;">👋 @User.FindFirst("FullName")?.Value</span>
                    <a href="/Account/Logout" style="font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.4rem 0.85rem;border:2px solid #1a1a1a;border-radius:2px;color:#1a1a1a;text-decoration:none;">Đăng xuất</a>
                }
                else
                {
                    <a href="/Account/Login" style="font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.4rem 0.85rem;border:2px solid #1a1a1a;border-radius:2px;color:#1a1a1a;text-decoration:none;">Đăng nhập</a>
                    <a href="/Account/Register" style="font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.4rem 0.85rem;border:2px solid #1a1a1a;border-radius:2px;background:#1a1a1a;color:white;text-decoration:none;">Đăng ký</a>
                }
            </div>
        </div>
    </nav>
    <main>
        @RenderBody()
    </main>
    <script>
        function fallbackImg(el) {
            el.onerror = null;
            el.style.display = 'none';
            var placeholder = document.createElement('div');
            placeholder.className = 'card-img-top d-flex align-items-center justify-content-center bg-light text-muted';
            placeholder.style.minHeight = '220px';
            placeholder.innerHTML = '<i class="bi bi-image" style="font-size: 48px;"></i>';
            el.parentElement.insertBefore(placeholder, el.nextSibling);
        }
    </script>
</body>
</html>
