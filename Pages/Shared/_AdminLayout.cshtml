<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;450;500;550;600;650;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/admin.css" rel="stylesheet" />
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <nav class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a href="/Admin/Dashboard">
                    <h5 class="sidebar-brand">ECommerce</h5>
                    <small class="sidebar-tag">Admin</small>
                </a>
            </div>
            <ul class="sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">
                        <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Products" ? "active" : "")" href="/Admin/Products/Index">
                        <i class="bi bi-box"></i> <span>Sản phẩm</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Categories" ? "active" : "")" href="/Admin/Categories/Index">
                        <i class="bi bi-tags"></i> <span>Danh mục</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Orders" ? "active" : "")" href="/Admin/Orders">
                        <i class="bi bi-truck"></i> <span>Đơn hàng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")" href="/Admin/Users">
                        <i class="bi bi-people"></i> <span>Người dùng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")" href="/Admin/Reports">
                        <i class="bi bi-bar-chart"></i> <span>Thống kê</span>
                    </a>
                </li>

                <li class="sidebar-divider"></li>

                <li class="nav-item">
                    <a class="nav-link" href="/Customer/Home">
                        <i class="bi bi-shop"></i> <span>Về trang người dùng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Account/Logout">
                        <i class="bi bi-box-arrow-right"></i> <span>Đăng xuất</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <span class="user-name">@User.FindFirst("FullName")?.Value</span>
                        <span class="user-role">Quản trị viên</span>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="admin-content">
            <nav class="admin-topbar glass-topbar">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn-sidebar-toggle d-lg-none" onclick="document.getElementById('adminSidebar').classList.toggle('show')">
                            <i class="bi bi-list"></i>
                        </button>
                        <span class="topbar-title">@ViewData["Title"]</span>
                    </div>
                    <div class="topbar-right">
                        <span class="topbar-user">
                            <i class="bi bi-person-circle"></i> @User.FindFirst("FullName")?.Value
                        </span>
                        <span class="admin-badge">Admin</span>
                    </div>
                </div>
            </nav>
            <div class="admin-main">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert-glass success animate-fade-in">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert-glass error animate-fade-in">@TempData["ErrorMessage"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
