@page
@model ECommerceFinalProject.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - ECommerce</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .auth-card { max-width: 520px; margin: 40px auto; background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.1); overflow: hidden; }
        .auth-header { background: #0d6efd; color: #fff; padding: 28px; text-align: center; }
        .auth-header h2 { margin: 0; font-weight: 700; }
        .auth-header p { margin: 8px 0 0; opacity: 0.85; }
        .auth-body { padding: 28px; }
        .form-floating { margin-bottom: 14px; }
        .btn-register { background: #0d6efd; color: #fff; font-weight: 600; padding: 12px; border-radius: 8px; border: none; width: 100%; font-size: 16px; }
        .btn-register:hover { background: #0b5ed7; color: #fff; }
        .form-control:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.2rem rgba(13,110,253,.25); }
        .text-danger { font-size: 13px; }
        .login-link { text-align: center; margin-top: 18px; }
        .login-link a { color: #0d6efd; text-decoration: none; font-weight: 600; }
        .login-link a:hover { text-decoration: underline; }
        .alert { border-radius: 8px; }
        .brand-logo { font-size: 42px; margin-bottom: 8px; }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <div class="brand-logo">🛒</div>
            <h2>Tạo tài khoản</h2>
            <p>Đăng ký để trở thành thành viên</p>
        </div>
        <div class="auth-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0 ps-3">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }
            <form method="post" asp-page="/Account/Register">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" id="tenDangNhap" name="TenDangNhap" placeholder="Tên đăng nhập" value="@ViewData["TenDangNhap"]" required />
                            <label for="tenDangNhap">Tên đăng nhập</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="email" class="form-control" id="email" name="Email" placeholder="Email" value="@ViewData["Email"]" required />
                            <label for="email">Email</label>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" id="ho" name="Ho" placeholder="Họ" value="@ViewData["Ho"]" required />
                            <label for="ho">Họ</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" id="ten" name="Ten" placeholder="Tên" value="@ViewData["Ten"]" required />
                            <label for="ten">Tên</label>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="date" class="form-control" id="ngaySinh" name="NgaySinh" placeholder="Ngày sinh" value="@ViewData["NgaySinh"]" />
                            <label for="ngaySinh">Ngày sinh</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="tel" class="form-control" id="soDienThoai" name="SoDienThoai" placeholder="Số điện thoại" value="@ViewData["SoDienThoai"]" />
                            <label for="soDienThoai">Số điện thoại</label>
                        </div>
                    </div>
                </div>
                <div class="form-floating">
                    <input type="password" class="form-control" id="matKhau" name="MatKhau" placeholder="Mật khẩu" required minlength="6" />
                    <label for="matKhau">Mật khẩu (tối thiểu 6 ký tự)</label>
                </div>
                <div class="form-floating">
                    <input type="password" class="form-control" id="xacNhanMatKhau" name="XacNhanMatKhau" placeholder="Xác nhận mật khẩu" required />
                    <label for="xacNhanMatKhau">Xác nhận mật khẩu</label>
                </div>
                <button type="submit" class="btn-register mt-2">Đăng ký</button>
            </form>
            <div class="login-link">
                Đã có tài khoản? <a href="/Account/Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</body>
</html>
