@page
@model ECommerceFinalProject.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký — ECommerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;450;500;550;600;650;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Outfit', sans-serif;
            background: #0b0b14;
            color: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 1.5rem;
            -webkit-font-smoothing: antialiased;
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            top: -40%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(99,102,241,0.12) 0%, transparent 70%);
            pointer-events: none;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -30%;
            left: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(168,85,247,0.10) 0%, transparent 70%);
            pointer-events: none;
        }
        .auth-glass {
            max-width: 520px;
            width: 100%;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(24px) saturate(1.4);
            -webkit-backdrop-filter: blur(24px) saturate(1.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
        }
        .auth-glass::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #6366f1, #a855f7, transparent);
        }
        .auth-header {
            padding: 2.5rem 2rem 1.5rem;
            text-align: center;
        }
        .auth-brand {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
            margin-bottom: 0.4rem;
        }
        .auth-header h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #f1f5f9;
            margin-top: 0.75rem;
        }
        .auth-header p {
            color: #94a3b8;
            font-size: 0.85rem;
            margin-top: 0.2rem;
        }
        .auth-body {
            padding: 0 2rem 2.5rem;
        }
        .form-group {
            margin-bottom: 1.1rem;
        }
        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 0.04em;
            color: #94a3b8;
            margin-bottom: 0.4rem;
        }
        .form-group input {
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            padding: 0.7rem 0.9rem;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            background: rgba(255,255,255,0.03);
            color: #f1f5f9;
            transition: all 0.25s;
        }
        .form-group input:focus {
            outline: none;
            border-color: #6366f1;
            background: rgba(99,102,241,0.06);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
        .form-group input::placeholder {
            color: #64748b;
        }
        .row-flex {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .row-flex .col-flex {
            flex: 1;
            min-width: 0;
        }
        .btn-auth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.82rem;
            font-weight: 550;
            padding: 0.8rem 2rem;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            color: white;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 4px 16px rgba(99,102,241,0.2);
            margin-top: 0.25rem;
        }
        .btn-auth:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(99,102,241,0.35);
        }
        .btn-auth:active {
            transform: scale(0.97);
        }
        .auth-footer {
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.85rem;
            color: #94a3b8;
        }
        .auth-footer a {
            color: #a5b4fc;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }
        .auth-footer a:hover {
            color: #c7d2fe;
        }
        .alert-glass {
            padding: 0.7rem 0.9rem;
            margin-bottom: 1rem;
            border-radius: 10px;
            font-size: 0.85rem;
            backdrop-filter: blur(10px);
        }
        .alert-glass.error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.15);
            color: #fca5a5;
        }
        .alert-glass.error ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="auth-glass">
        <div class="auth-header">
            <span class="auth-brand">ECommerce</span>
            <h2>Tạo tài khoản</h2>
            <p>Đăng ký để trở thành thành viên</p>
        </div>
        <div class="auth-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-glass error">
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }
            <form method="post" asp-page="/Account/Register">
                <div class="row-flex">
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="tenDangNhap"><i class="bi bi-person" style="margin-right:0.3rem;"></i>Tên đăng nhập</label>
                            <input type="text" id="tenDangNhap" name="TenDangNhap" placeholder="Tên đăng nhập" value="@ViewData["TenDangNhap"]" required />
                        </div>
                    </div>
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="email"><i class="bi bi-envelope" style="margin-right:0.3rem;"></i>Email</label>
                            <input type="email" id="email" name="Email" placeholder="Email" value="@ViewData["Email"]" required />
                        </div>
                    </div>
                </div>
                <div class="row-flex">
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="ho">Họ</label>
                            <input type="text" id="ho" name="Ho" placeholder="Họ" value="@ViewData["Ho"]" required />
                        </div>
                    </div>
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="ten">Tên</label>
                            <input type="text" id="ten" name="Ten" placeholder="Tên" value="@ViewData["Ten"]" required />
                        </div>
                    </div>
                </div>
                <div class="row-flex">
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="ngaySinh"><i class="bi bi-calendar" style="margin-right:0.3rem;"></i>Ngày sinh</label>
                            <input type="date" id="ngaySinh" name="NgaySinh" placeholder="Ngày sinh" value="@ViewData["NgaySinh"]" />
                        </div>
                    </div>
                    <div class="col-flex">
                        <div class="form-group">
                            <label for="soDienThoai"><i class="bi bi-telephone" style="margin-right:0.3rem;"></i>Số điện thoại</label>
                            <input type="tel" id="soDienThoai" name="SoDienThoai" placeholder="Số điện thoại" value="@ViewData["SoDienThoai"]" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="matKhau"><i class="bi bi-lock" style="margin-right:0.3rem;"></i>Mật khẩu</label>
                    <input type="password" id="matKhau" name="MatKhau" placeholder="Tối thiểu 6 ký tự" required minlength="6" />
                </div>
                <div class="form-group">
                    <label for="xacNhanMatKhau"><i class="bi bi-lock-fill" style="margin-right:0.3rem;"></i>Xác nhận mật khẩu</label>
                    <input type="password" id="xacNhanMatKhau" name="XacNhanMatKhau" placeholder="Nhập lại mật khẩu" required />
                </div>
                <button type="submit" class="btn-auth"><i class="bi bi-person-plus"></i> Đăng ký</button>
            </form>
            <div class="auth-footer">
                Đã có tài khoản? <a href="/Account/Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</body>
</html>
