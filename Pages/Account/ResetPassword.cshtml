@page
@model ECommerceFinalProject.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu — ECommerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;450;500;550;600;650;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Outfit', sans-serif;
            background: #0b0b14;
            color: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 1.5rem;
            -webkit-font-smoothing: antialiased;
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            top: -40%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(99,102,241,0.12) 0%, transparent 70%);
            pointer-events: none;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -30%;
            left: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(168,85,247,0.10) 0%, transparent 70%);
            pointer-events: none;
        }
        .auth-glass {
            max-width: 460px;
            width: 100%;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(24px) saturate(1.4);
            -webkit-backdrop-filter: blur(24px) saturate(1.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
        }
        .auth-glass::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #6366f1, #a855f7, transparent);
        }
        .auth-header {
            padding: 2.5rem 2rem 1.5rem;
            text-align: center;
        }
        .auth-brand {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
            margin-bottom: 0.4rem;
        }
        .auth-header h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #f1f5f9;
            margin-top: 0.75rem;
        }
        .auth-header p {
            color: #94a3b8;
            font-size: 0.85rem;
            margin-top: 0.2rem;
            line-height: 1.5;
        }
        .email-highlight {
            color: #a5b4fc;
            font-weight: 500;
        }
        .auth-body {
            padding: 0 2rem 2.5rem;
        }
        .form-group {
            margin-bottom: 1.1rem;
            position: relative;
        }
        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 0.04em;
            color: #94a3b8;
            margin-bottom: 0.4rem;
        }
        .form-group input {
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            padding: 0.7rem 0.9rem;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            background: rgba(255,255,255,0.03);
            color: #f1f5f9;
            transition: all 0.25s;
        }
        .form-group input:focus {
            outline: none;
            border-color: #6366f1;
            background: rgba(99,102,241,0.06);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
        .form-group input::placeholder {
            color: #64748b;
        }
        .password-wrapper {
            position: relative;
        }
        .password-wrapper input {
            padding-right: 2.8rem;
        }
        .toggle-password {
            position: absolute;
            right: 0.7rem;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            padding: 0.35rem 0.5rem;
            font-size: 1.05rem;
            line-height: 1;
            border-radius: 6px;
            transition: color 0.2s, background 0.2s;
        }
        .toggle-password:hover {
            color: #c7d2fe;
            background: rgba(99,102,241,0.08);
        }
        .otp-wrapper {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .otp-input {
            width: 48px !important;
            height: 56px;
            text-align: center;
            font-size: 1.4rem !important;
            font-weight: 700;
            letter-spacing: 0;
        }
        .btn-auth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.82rem;
            font-weight: 550;
            padding: 0.8rem 2rem;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            color: white;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 4px 16px rgba(99,102,241,0.2);
            margin-top: 0.5rem;
        }
        .btn-auth:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(99,102,241,0.35);
        }
        .btn-auth:active {
            transform: scale(0.97);
        }
        .resend-link {
            text-align: center;
            margin-top: 1rem;
            font-size: 0.85rem;
            color: #94a3b8;
        }
        .resend-link a {
            color: #a5b4fc;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
            cursor: pointer;
        }
        .resend-link a:hover {
            color: #c7d2fe;
            text-decoration: underline;
        }
        .resend-link a.disabled {
            color: #475569;
            cursor: not-allowed;
            pointer-events: none;
        }
        .auth-footer {
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.85rem;
            color: #94a3b8;
        }
        .auth-footer a {
            color: #a5b4fc;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }
        .auth-footer a:hover {
            color: #c7d2fe;
        }
        .alert-glass {
            padding: 0.7rem 0.9rem;
            margin-bottom: 1rem;
            border-radius: 10px;
            font-size: 0.85rem;
        }
        .alert-glass.error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.15);
            color: #fca5a5;
        }
        .alert-glass.dev-fallback {
            background: rgba(234,179,8,0.12);
            border: 1px solid rgba(234,179,8,0.4);
            color: #fde047;
        }
        .alert-glass.dev-fallback .otp-display {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 4px;
            color: #facc15;
        }
        .hidden-otp {
            display: none;
        }
    </style>
</head>
<body>
    <div class="auth-glass">
        <div class="auth-header">
            <span class="auth-brand">ECommerce</span>
            <h2><i class="bi bi-shield-lock" style="margin-right:0.3rem;"></i>Đặt lại mật khẩu</h2>
            <p>
                Nhập mã OTP đã gửi tới<br />
                <span class="email-highlight">@Model.Email</span>
            </p>
        </div>
        <div class="auth-body">
            @if (!string.IsNullOrEmpty(Model.DevOtp))
            {
                <div class="alert-glass dev-fallback">
                    <strong>Dev fallback (email that bai):</strong><br />
                    Ma OTP cua ban la: <span class="otp-display">@Model.DevOtp</span>
                </div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-glass error">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            }
            <form method="post">
                <input type="hidden" name="Email" value="@Model.Email" />
                <div class="form-group">
                    <label for="otp1"><i class="bi bi-shield-check" style="margin-right:0.3rem;"></i>Mã OTP</label>
                    <div class="otp-wrapper">
                        <input type="text" class="otp-input" maxlength="1" id="otp1" inputmode="numeric" />
                        <input type="text" class="otp-input" maxlength="1" id="otp2" inputmode="numeric" />
                        <input type="text" class="otp-input" maxlength="1" id="otp3" inputmode="numeric" />
                        <input type="text" class="otp-input" maxlength="1" id="otp4" inputmode="numeric" />
                        <input type="text" class="otp-input" maxlength="1" id="otp5" inputmode="numeric" />
                        <input type="text" class="otp-input" maxlength="1" id="otp6" inputmode="numeric" />
                    </div>
                    <input type="text" name="MaXacThuc" id="MaXacThuc" class="hidden-otp" />
                </div>
                <div class="form-group">
                    <label for="matKhauMoi"><i class="bi bi-lock" style="margin-right:0.3rem;"></i>Mật khẩu mới</label>
                    <div class="password-wrapper">
                        <input type="password" id="matKhauMoi" name="MatKhauMoi" placeholder="Tối đa 8 ký tự" required minlength="6" maxlength="8" autocomplete="new-password" />
                        <button type="button" class="toggle-password" data-target="matKhauMoi" aria-label="Hiện/ẩn mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="form-group">
                    <label for="xacNhanMatKhau"><i class="bi bi-lock-fill" style="margin-right:0.3rem;"></i>Xác nhận mật khẩu mới</label>
                    <div class="password-wrapper">
                        <input type="password" id="xacNhanMatKhau" name="XacNhanMatKhau" placeholder="Nhập lại mật khẩu mới" required maxlength="8" autocomplete="new-password" />
                        <button type="button" class="toggle-password" data-target="xacNhanMatKhau" aria-label="Hiện/ẩn mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn-auth"><i class="bi bi-check2-circle"></i> Đặt lại mật khẩu</button>
            </form>
            <div class="resend-link">
                Không nhận được mã? <a id="resendBtn" href="javascript:void(0)">Gửi lại</a> <span id="countdown"></span>
            </div>
            <div class="auth-footer">
                <a href="/Account/Login"><i class="bi bi-arrow-left" style="margin-right:0.2rem;"></i>Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
    <script>
        // OTP 6 ô tự động focus
        (function () {
            const otpInputs = document.querySelectorAll('.otp-input');
            const hidden = document.getElementById('MaXacThuc');

            function syncHidden() {
                let v = '';
                otpInputs.forEach(i => v += i.value);
                hidden.value = v;
            }

            otpInputs.forEach((input, idx) => {
                input.addEventListener('input', function (e) {
                    let v = e.target.value.replace(/[^0-9]/g, '');
                    e.target.value = v;
                    if (v && idx < otpInputs.length - 1) otpInputs[idx + 1].focus();
                    syncHidden();
                });
                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                        otpInputs[idx - 1].focus();
                    }
                });
                input.addEventListener('paste', function (e) {
                    e.preventDefault();
                    const data = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '').slice(0, 6);
                    for (let i = 0; i < data.length; i++) otpInputs[i].value = data[i];
                    otpInputs[Math.min(data.length, 5)].focus();
                    syncHidden();
                });
            });
            syncHidden();
        })();

        // Con mắt show/hide password
        document.querySelectorAll('.toggle-password').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var target = document.getElementById(btn.getAttribute('data-target'));
                if (!target) return;
                var isPassword = target.type === 'password';
                target.type = isPassword ? 'text' : 'password';
                var icon = btn.querySelector('i');
                icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
            });
        });

        // Gửi lại OTP với countdown 60s
        (function () {
            const resendBtn = document.getElementById('resendBtn');
            const countdownEl = document.getElementById('countdown');
            let seconds = 60;
            let timer = null;

            function startCountdown() {
                resendBtn.classList.add('disabled');
                countdownEl.textContent = '(' + seconds + 's)';
                timer = setInterval(() => {
                    seconds--;
                    if (seconds <= 0) {
                        clearInterval(timer);
                        resendBtn.classList.remove('disabled');
                        countdownEl.textContent = '';
                        seconds = 60;
                    } else {
                        countdownEl.textContent = '(' + seconds + 's)';
                    }
                }, 1000);
            }

            resendBtn.addEventListener('click', async function () {
                if (resendBtn.classList.contains('disabled')) return;
                resendBtn.textContent = 'Đang gửi...';
                try {
                    const res = await fetch('?handler=Resend&email=' + encodeURIComponent('@Model.Email'));
                    const data = await res.json();
                    alert(data.message || 'Da gui lai ma OTP');
                    if (data.devOtp) alert('Dev OTP: ' + data.devOtp);
                } catch (e) {
                    alert('Loi: ' + e.message);
                } finally {
                    resendBtn.textContent = 'Gửi lại';
                    startCountdown();
                }
            });

            // Khoi dong countdown khi load trang
            startCountdown();
        })();
    </script>
</body>
</html>
