@page
@model ECommerceFinalProject.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — ECommerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,400;6..96,500;6..96,600;6..96,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #f5f3ef;
            font-family: 'Outfit', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 1rem;
        }
        .auth-card {
            max-width: 420px;
            width: 100%;
            background: #fff;
            border: 1px solid #e8e5e0;
            border-radius: 4px;
        }
        .auth-header {
            padding: 2.5rem 2rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid #e8e5e0;
        }
        .auth-header .brand {
            font-family: 'Bodoni Moda', Georgia, serif;
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.02em;
            color: #1a1a1a;
            display: block;
            margin-bottom: 0.5rem;
        }
        .auth-header .brand small {
            font-family: 'Outfit', sans-serif;
            font-size: 0.65rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #9e9790;
            display: block;
            margin-top: 2px;
        }
        .auth-header h2 {
            font-family: 'Bodoni Moda', Georgia, serif;
            font-size: 1.4rem;
            font-weight: 600;
            color: #1a1a1a;
            margin-top: 0.5rem;
        }
        .auth-header p {
            color: #6b6560;
            font-size: 0.85rem;
            margin-top: 0.25rem;
        }
        .auth-body {
            padding: 1.5rem 2rem 2rem;
        }
        .form-group {
            margin-bottom: 1rem;
        }
        .form-group label {
            font-family: 'Outfit', sans-serif;
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: #6b6560;
            display: block;
            margin-bottom: 0.35rem;
        }
        .form-group input {
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            padding: 0.65rem 0.85rem;
            border: 1px solid #e8e5e0;
            border-radius: 2px;
            background: #faf9f6;
            color: #1a1a1a;
            transition: border-color 0.2s;
        }
        .form-group input:focus {
            outline: none;
            border-color: #1a1a1a;
            background: #fff;
        }
        .form-group input::placeholder {
            color: #9e9790;
        }
        .form-check {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
        }
        .form-check input {
            accent-color: #1a1a1a;
        }
        .form-check label {
            font-family: 'Outfit', sans-serif;
            font-size: 0.8rem;
            color: #6b6560;
        }
        .btn-auth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            font-family: 'Outfit', sans-serif;
            font-size: 0.8rem;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 0.85rem 2rem;
            border: 2px solid #1a1a1a;
            border-radius: 2px;
            background: #1a1a1a;
            color: white;
            cursor: pointer;
            transition: all 0.25s;
        }
        .btn-auth:hover {
            background: #333;
            border-color: #333;
        }
        .auth-footer {
            text-align: center;
            margin-top: 1.25rem;
            font-family: 'Outfit', sans-serif;
            font-size: 0.85rem;
            color: #6b6560;
        }
        .auth-footer a {
            color: #1a1a1a;
            font-weight: 500;
            text-decoration: none;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s;
        }
        .auth-footer a:hover {
            border-bottom-color: #1a1a1a;
        }
        .alert {
            padding: 0.65rem 0.85rem;
            margin-bottom: 1rem;
            border-radius: 2px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.85rem;
        }
        .alert-success {
            background: #f0faf0;
            border: 1px solid #c6f6d5;
            color: #276749;
        }
        .alert-danger {
            background: #fff5f5;
            border: 1px solid #fed7d7;
            color: #9b2c2c;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <span class="brand">
                ECommerce
                <small>Cửa hàng công nghệ</small>
            </span>
            <h2>Chào mừng quay trở lại</h2>
            <p>Đăng nhập vào tài khoản của bạn</p>
        </div>
        <div class="auth-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            }
            <form method="post" asp-page="/Account/Login">
                <div class="form-group">
                    <label for="taiKhoan">Tài khoản</label>
                    <input type="text" id="taiKhoan" name="TaiKhoan" placeholder="Tên đăng nhập hoặc Email" value="@ViewData["TaiKhoan"]" required />
                </div>
                <div class="form-group">
                    <label for="matKhau">Mật khẩu</label>
                    <input type="password" id="matKhau" name="MatKhau" placeholder="Nhập mật khẩu" required />
                </div>
                <div class="form-check">
                    <input type="checkbox" id="ghiNho" name="GhiNho" value="true" checked="@ViewData["GhiNho"]" />
                    <label for="ghiNho">Ghi nhớ đăng nhập</label>
                </div>
                <button type="submit" class="btn-auth">Đăng nhập</button>
            </form>
            <div class="auth-footer">
                Chưa có tài khoản? <a href="/Account/Register">Đăng ký ngay</a>
            </div>
        </div>
    </div>
</body>
</html>
