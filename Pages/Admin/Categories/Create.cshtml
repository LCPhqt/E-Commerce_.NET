@page
@model ECommerceFinalProject.Pages.Admin.Categories.CreateModel
@{
    ViewData["Title"] = "Thêm danh mục";
    ViewData["ActivePage"] = "Categories";
}

<div class="page-header">
    <h4>Thêm danh mục</h4>
    <a href="/Admin/Categories/Index" class="btn-admin"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card-glass animated" style="max-width:560px;">
    <form method="post">
        <div class="mb-3">
            <label>Tên danh mục <span style="color:var(--admin-accent);">*</span></label>
            <input type="text" name="Ten" class="form-glass" required maxlength="100" />
        </div>
        <div class="mb-3">
            <label>Mô tả</label>
            <textarea name="MoTa" class="form-glass" rows="3" maxlength="500"></textarea>
        </div>
        <button type="submit" class="btn-admin primary"><i class="bi bi-save"></i> Lưu danh mục</button>
    </form>
</div>
