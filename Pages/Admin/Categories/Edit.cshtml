@page
@model ECommerceFinalProject.Pages.Admin.Categories.EditModel
@{
    ViewData["Title"] = "Sửa danh mục";
    ViewData["ActivePage"] = "Categories";
}

<div class="page-header">
    <h4><i class="bi bi-pencil"></i> Sửa danh mục</h4>
    <a href="/Admin/Categories/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Category == null)
{
    <div class="alert alert-danger">Danh mục không tồn tại.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <input type="hidden" name="Id" value="@Model.Category.Id" />
                <div class="mb-3">
                    <label class="form-label">Tên danh mục <span class="text-danger">*</span></label>
                    <input type="text" name="Ten" class="form-control" value="@Model.Category.Ten" required maxlength="100" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="MoTa" class="form-control" rows="3" maxlength="500">@Model.Category.MoTa</textarea>
                </div>
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Cập nhật</button>
            </form>
        </div>
    </div>
}
