@page
@model ECommerceFinalProject.Pages.Admin.Categories.EditModel
@{
    ViewData["Title"] = "Sửa danh mục";
    ViewData["ActivePage"] = "Categories";
}

<div class="page-header">
    <h4>Sửa danh mục</h4>
    <a href="/Admin/Categories/Index" class="btn-admin"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Category == null)
{
    <div class="alert-glass error">Danh mục không tồn tại.</div>
}
else
{
    <div class="card-glass animated" style="max-width:560px;">
        <form method="post">
            <div class="mb-3">
                <label>Tên danh mục <span style="color:var(--admin-accent);">*</span></label>
                <input type="text" name="Ten" class="form-glass" value="@Model.Category.Ten" required maxlength="100" />
            </div>
            <div class="mb-3">
                <label>Mô tả</label>
                <textarea name="MoTa" class="form-glass" rows="3" maxlength="500">@Model.Category.MoTa</textarea>
            </div>
            <button type="submit" class="btn-admin primary"><i class="bi bi-save"></i> Cập nhật</button>
        </form>
    </div>
}
