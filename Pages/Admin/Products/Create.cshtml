@page
@model ECommerceFinalProject.Pages.Admin.Products.CreateModel
@{
    ViewData["Title"] = "Thêm sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="admin-light-section">
    <div class="page-header">
        <h4>Thêm sản phẩm</h4>
        <a href="/Admin/Products/Index" class="admin-light-btn"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-light-card" style="max-width:720px;">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Tên sản phẩm <span style="color:#dc2626;">*</span></label>
                    <input type="text" name="TenSanPham" class="admin-light-input" required maxlength="200" />
                </div>
                <div class="col-md-6">
                    <label>Danh mục <span style="color:#dc2626;">*</span></label>
                    <select name="DanhMucId" class="admin-light-input" required>
                        <option value="">-- Chọn danh mục --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Ten</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label>Giá <span style="color:#dc2626;">*</span></label>
                    <input type="number" name="Gia" class="admin-light-input" required step="0.01" min="0" />
                </div>
                <div class="col-md-6">
                    <label>Số lượng tồn</label>
                    <input type="number" name="SoLuongTon" class="admin-light-input" value="0" min="0" />
                </div>
            </div>
            <div class="mt-3">
                <label>Hình ảnh URL</label>
                <input type="url" name="HinhAnhUrl" class="admin-light-input" placeholder="https://..." />
            </div>
            <div class="mt-3">
                <label>Mô tả chi tiết</label>
                <small style="display:block;color:#9ca3af;margin-bottom:0.5rem;font-size:0.78rem;">
                    Hỗ trợ HTML: &lt;h3&gt;, &lt;p&gt;, &lt;ul&gt;/&lt;ol&gt;, &lt;li&gt;, &lt;strong&gt;, &lt;em&gt;, &lt;br&gt;
                </small>
                <textarea name="MoTa" class="admin-light-input" rows="12" style="font-family:var(--font-mono,'Courier New',monospace);font-size:0.85rem;"></textarea>
            </div>
            <div class="mt-4">
                <button type="submit" class="admin-light-btn primary"><i class="bi bi-save"></i> Lưu sản phẩm</button>
            </div>
        </form>
    </div>
</div>
