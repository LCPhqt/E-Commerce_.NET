@page
@model ECommerceFinalProject.Pages.Admin.Products.DeleteModel
@{
    ViewData["Title"] = "Xóa sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="page-header">
    <h4><i class="bi bi-trash"></i> Xóa sản phẩm</h4>
    <a href="/Admin/Products/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Product == null)
{
    <div class="alert alert-danger">Sản phẩm không tồn tại.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-exclamation-triangle text-warning" style="font-size: 64px;"></i>
            <h5 class="mt-3">Bạn có chắc muốn xóa sản phẩm này?</h5>
            <p class="text-muted">Hành động này không thể hoàn tác.</p>
            <table class="table table-bordered text-start mx-auto" style="max-width: 500px;">
                <tr><th>Tên sản phẩm</th><td>@Model.Product.TenSanPham</td></tr>
                <tr><th>Danh mục</th><td>@Model.Product.DanhMuc?.Ten</td></tr>
                <tr><th>Giá</th><td>@Model.Product.Gia.ToString("N0")đ</td></tr>
                <tr><th>Tồn kho</th><td>@Model.Product.SoLuongTon</td></tr>
            </table>
            <form method="post">
                <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-trash"></i> Xác nhận xóa</button>
                <a href="/Admin/Products/Index" class="btn btn-secondary btn-lg">Hủy</a>
            </form>
        </div>
    </div>
}
