@page
@model ECommerceFinalProject.Pages.Admin.Products.DeleteModel
@{
    ViewData["Title"] = "Xóa sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="page-header">
    <h4>Xóa sản phẩm</h4>
    <a href="/Admin/Products/Index" class="btn-editorial-admin"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Product == null)
{
    <div class="alert-editorial-admin error">Sản phẩm không tồn tại.</div>
}
else
{
    <div class="card-editorial text-center py-5">
        <i class="bi bi-exclamation-triangle" style="font-size: 64px; color: var(--accent);"></i>
        <h3 style="font-family:var(--font-display);font-size:1.3rem;font-weight:600;margin-top:1rem;">Bạn có chắc muốn xóa sản phẩm này?</h3>
        <p style="color:var(--text-muted);">Hành động này không thể hoàn tác.</p>
        <div style="max-width:400px;margin:1.5rem auto;">
            <table style="width:100%;font-family:var(--font-body);font-size:0.9rem;">
                <tr><td style="padding:0.5rem;font-weight:500;color:var(--text-secondary);">Tên sản phẩm</td><td style="padding:0.5rem;">@Model.Product.TenSanPham</td></tr>
                <tr><td style="padding:0.5rem;font-weight:500;color:var(--text-secondary);">Danh mục</td><td style="padding:0.5rem;">@Model.Product.DanhMuc?.Ten</td></tr>
                <tr><td style="padding:0.5rem;font-weight:500;color:var(--text-secondary);">Giá</td><td style="padding:0.5rem;">@Model.Product.Gia.ToString("N0")₫</td></tr>
                <tr><td style="padding:0.5rem;font-weight:500;color:var(--text-secondary);">Tồn kho</td><td style="padding:0.5rem;">@Model.Product.SoLuongTon</td></tr>
            </table>
        </div>
        <form method="post">
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn-editorial-admin danger"><i class="bi bi-trash"></i> Xác nhận xóa</button>
                <a href="/Admin/Products/Index" class="btn-editorial-admin">Hủy</a>
            </div>
        </form>
    </div>
}
