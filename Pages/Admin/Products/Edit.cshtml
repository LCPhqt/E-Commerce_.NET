@page
@model ECommerceFinalProject.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="admin-light-section">
    <div class="page-header">
        <h4>Sửa sản phẩm</h4>
        <a href="/Admin/Products/Index" class="admin-light-btn"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    @if (Model.Product == null)
    {
        <div style="padding:1rem;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;color:#991b1b;">Sản phẩm không tồn tại.</div>
    }
    else
    {
        <div class="admin-light-card" style="max-width:720px;">
            <form method="post">
                <input type="hidden" name="Id" value="@Model.Product.Id" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label>Tên sản phẩm <span style="color:#dc2626;">*</span></label>
                        <input type="text" name="TenSanPham" class="admin-light-input" value="@Model.Product.TenSanPham" required maxlength="200" />
                    </div>
                    <div class="col-md-6">
                        <label>Danh mục <span style="color:#dc2626;">*</span></label>
                        <select name="DanhMucId" class="admin-light-input" required>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(cat.Id == Model.Product.DanhMucId)">@cat.Ten</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label>Giá <span style="color:#dc2626;">*</span></label>
                        <input type="number" name="Gia" class="admin-light-input" value="@Model.Product.Gia" required step="0.01" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label>Số lượng tồn</label>
                        <input type="number" name="SoLuongTon" class="admin-light-input" value="@Model.Product.SoLuongTon" min="0" />
                    </div>
                </div>
                <div class="mt-3">
                    <label>Hình ảnh URL</label>
                    <input type="url" name="HinhAnhUrl" class="admin-light-input" value="@Model.Product.HinhAnhUrl" placeholder="https://..." />
                </div>
                <div class="mt-3">
                    <label>Mô tả</label>
                    <textarea name="MoTa" class="admin-light-input" rows="4" maxlength="2000">@Model.Product.MoTa</textarea>
                </div>
                <div class="mt-4">
                    <button type="submit" class="admin-light-btn primary"><i class="bi bi-save"></i> Cập nhật</button>
                </div>
            </form>
        </div>
    }
</div>
