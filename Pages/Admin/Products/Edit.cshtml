@page
@model ECommerceFinalProject.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="page-header">
    <h4><i class="bi bi-pencil"></i> Sửa sản phẩm</h4>
    <a href="/Admin/Products/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Product == null)
{
    <div class="alert alert-danger">Sản phẩm không tồn tại.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <input type="hidden" name="Id" value="@Model.Product.Id" />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" name="TenSanPham" class="form-control" value="@Model.Product.TenSanPham" required maxlength="200" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Danh mục <span class="text-danger">*</span></label>
                        <select name="DanhMucId" class="form-select" required>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(cat.Id == Model.Product.DanhMucId)">@cat.Ten</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Giá <span class="text-danger">*</span></label>
                        <input type="number" name="Gia" class="form-control" value="@Model.Product.Gia" required step="0.01" min="0" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số lượng tồn</label>
                        <input type="number" name="SoLuongTon" class="form-control" value="@Model.Product.SoLuongTon" min="0" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Hình ảnh URL</label>
                    <input type="url" name="HinhAnhUrl" class="form-control" value="@Model.Product.HinhAnhUrl" placeholder="https://..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="MoTa" class="form-control" rows="4" maxlength="2000">@Model.Product.MoTa</textarea>
                </div>
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Cập nhật</button>
            </form>
        </div>
    </div>
}
