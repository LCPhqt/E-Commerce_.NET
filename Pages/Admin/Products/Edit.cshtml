@page
@model ECommerceFinalProject.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
    ViewData["ActivePage"] = "Products";
}

<div class="page-header">
    <h4>Sửa sản phẩm</h4>
    <a href="/Admin/Products/Index" class="btn-editorial-admin"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Product == null)
{
    <div class="alert-editorial-admin error">Sản phẩm không tồn tại.</div>
}
else
{
    <div class="card-editorial">
        <form method="post">
            <input type="hidden" name="Id" value="@Model.Product.Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Tên sản phẩm <span style="color:var(--accent);">*</span></label>
                    <input type="text" name="TenSanPham" class="form-editorial" value="@Model.Product.TenSanPham" required maxlength="200" />
                </div>
                <div class="col-md-6">
                    <label>Danh mục <span style="color:var(--accent);">*</span></label>
                    <select name="DanhMucId" class="form-editorial" required>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(cat.Id == Model.Product.DanhMucId)">@cat.Ten</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label>Giá <span style="color:var(--accent);">*</span></label>
                    <input type="number" name="Gia" class="form-editorial" value="@Model.Product.Gia" required step="0.01" min="0" />
                </div>
                <div class="col-md-6">
                    <label>Số lượng tồn</label>
                    <input type="number" name="SoLuongTon" class="form-editorial" value="@Model.Product.SoLuongTon" min="0" />
                </div>
            </div>
            <div class="mt-3">
                <label>Hình ảnh URL</label>
                <input type="url" name="HinhAnhUrl" class="form-editorial" value="@Model.Product.HinhAnhUrl" placeholder="https://..." />
            </div>
            <div class="mt-3">
                <label>Mô tả</label>
                <textarea name="MoTa" class="form-editorial" rows="4" maxlength="2000">@Model.Product.MoTa</textarea>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn-editorial-admin primary"><i class="bi bi-save"></i> Cập nhật</button>
            </div>
        </form>
    </div>
}
