@page
@model ECommerceFinalProject.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "Thống kê";
    ViewData["ActivePage"] = "Reports";
}

<div class="page-header">
    <h4>Thống kê doanh thu</h4>
</div>

<div class="row g-4 mb-4 stagger-children">
    <div class="col-md-4">
        <div class="stat-card stat-revenue">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalRevenue.ToString("N0")₫</div>
                    <div class="stat-label">Tổng doanh thu (đã giao)</div>
                </div>
                <div class="stat-icon" style="color:#c084fc;"><i class="bi bi-cash-stack"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card stat-products">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalOrders</div>
                    <div class="stat-label">Tổng đơn hàng</div>
                </div>
                <div class="stat-icon" style="color:#818cf8;"><i class="bi bi-truck"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card stat-orders">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.DeliveredOrders</div>
                    <div class="stat-label">Đơn đã giao</div>
                </div>
                <div class="stat-icon" style="color:#34d399;"><i class="bi bi-check-circle"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="card-glass">
    <h3 class="card-title mb-3">Chi tiết đơn hàng đã giao</h3>
    @if (Model.DeliveredOrderDetails.Any())
    {
        <div class="table-responsive">
            <table class="table table-admin" style="margin:0;">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Sản phẩm</th>
                        <th>SL</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.DeliveredOrderDetails)
                    {
                        <tr>
                            <td style="font-weight:600;color:var(--admin-text);">#@detail.OrderId</td>
                            <td>@detail.CustomerName</td>
                            <td>@detail.OrderDate.ToString("dd/MM/yyyy")</td>
                            <td>@detail.ProductName</td>
                            <td>@detail.Quantity</td>
                            <td>@detail.UnitPrice.ToString("N0")₫</td>
                            <td style="font-weight:500;color:var(--admin-text);">@detail.TotalPrice.ToString("N0")₫</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="color:var(--admin-text-muted);margin:0;">Chưa có đơn hàng nào được giao.</p>
    }
</div>
