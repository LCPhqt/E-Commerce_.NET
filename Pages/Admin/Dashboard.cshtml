@page
@model ECommerceFinalProject.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="page-header">
    <h4>Dashboard</h4>
    <span style="font-size:0.82rem;color:var(--admin-text-muted);">
        <i class="bi bi-calendar3"></i> Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")
    </span>
</div>

<div class="row g-4 mb-4 stagger-children">
    <div class="col-md-3">
        <div class="stat-card stat-products">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalProducts</div>
                    <div class="stat-label">Sản phẩm</div>
                </div>
                <div class="stat-icon" style="color:#818cf8;"><i class="bi bi-box"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-orders">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalOrders</div>
                    <div class="stat-label">Đơn hàng</div>
                </div>
                <div class="stat-icon" style="color:#34d399;"><i class="bi bi-truck"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-users">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalUsers</div>
                    <div class="stat-label">Người dùng</div>
                </div>
                <div class="stat-icon" style="color:#fbbf24;"><i class="bi bi-people"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-revenue">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-number">@Model.TotalRevenue.ToString("N0")₫</div>
                    <div class="stat-label">Doanh thu</div>
                </div>
                <div class="stat-icon" style="color:#c084fc;"><i class="bi bi-cash-stack"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card-glass">
            <h3 class="card-title mb-3">Trạng thái đơn hàng</h3>
            @if (Model.OrderStatusCounts.Any())
            {
                <table class="table table-admin" style="margin:0;">
                    @foreach (var status in Model.OrderStatusCounts)
                    {
                        <tr>
                            <td>
                                <span class="status-badge
                                    @(status.Key == "Chờ xử lý" ? "status-pending" :
                                      status.Key == "Đang giao" ? "status-shipping" :
                                      status.Key == "Đã giao" ? "status-delivered" :
                                      "status-cancelled")">
                                    @status.Key
                                </span>
                            </td>
                            <td class="text-end" style="color:var(--admin-text);"><strong>@status.Value</strong></td>
                        </tr>
                    }
                </table>
            }
            else
            {
                <p style="color:var(--admin-text-muted);margin:0;">Chưa có đơn hàng.</p>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="card-glass">
            <h3 class="card-title mb-3">Thao tác nhanh</h3>
            <div class="d-grid gap-2">
                <a href="/Admin/Products/Create" class="btn-admin primary"><i class="bi bi-plus-circle"></i> Thêm sản phẩm mới</a>
                <a href="/Admin/Categories/Create" class="btn-admin"><i class="bi bi-plus-circle"></i> Thêm danh mục mới</a>
                <a href="/Admin/Orders" class="btn-admin"><i class="bi bi-truck"></i> Xem đơn hàng mới</a>
            </div>
        </div>
    </div>
</div>
