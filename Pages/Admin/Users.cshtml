@page
@model ECommerceFinalProject.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActivePage"] = "Users";
}

<div class="page-header">
    <h4>Quản lý người dùng</h4>
    <span style="font-size:0.82rem;color:var(--admin-text-muted);">@Model.Users.Count() người dùng</span>
</div>

<div class="table-admin">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Tên đăng nhập</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="5" class="text-center py-4" style="color:var(--admin-text-muted);">Chưa có người dùng nào.</td></tr>
                }
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td style="font-weight:500;color:var(--admin-text);">@user.TenDangNhap</td>
                        <td>@user.Ho @user.Ten</td>
                        <td>@user.Email</td>
                        <td>@(user.SoDienThoai ?? "\u2014")</td>
                        <td>
                            <span class="badge-admin" style="background:rgba(99,102,241,0.1);color:#818cf8;@(user.VaiTro == "Admin" ? "background:linear-gradient(135deg,#6366f1,#a855f7);color:white;" : "")">
                                @user.VaiTro
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
