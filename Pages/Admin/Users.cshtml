@page
@model ECommerceFinalProject.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActivePage"] = "Users";
}

<div class="page-header">
    <h4><i class="bi bi-people"></i> Quản lý người dùng</h4>
</div>

<div class="card shadow-sm table-admin">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Tên đăng nhập</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Chưa có người dùng nào.</td></tr>
                }
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="fw-bold">@user.TenDangNhap</td>
                        <td>@user.Ho @user.Ten</td>
                        <td>@user.Email</td>
                        <td>@(user.SoDienThoai ?? "—")</td>
                        <td>
                            <span class="badge @(user.VaiTro == "Admin" ? "bg-danger" : "bg-primary")">@user.VaiTro</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
