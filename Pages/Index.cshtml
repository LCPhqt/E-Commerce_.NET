@page
@model ECommerceFinalProject.Pages.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-4">Chào mừng đến với ECommerce</h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="lead mt-3">Xin chào, <strong>@User.Identity.Name</strong>!</p>
            <p>Chúc bạn một ngày mua sắm vui vẻ!</p>
            <a href="/Customer/Products"
               style="display:inline-block;margin-top:1.5rem;font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.6rem 1.5rem;border:2px solid #1a1a1a;border-radius:2px;background:#1a1a1a;color:white;text-decoration:none;">
                Mua sắm ngay
            </a>
        }
        else
        {
            <p class="lead mt-3">
                Vui lòng <a href="/Account/Login">đăng nhập</a> hoặc <a href="/Account/Register">đăng ký</a> để tiếp tục.
            </p>
        }
    </div>
</div>
