@page
@model ECommerceFinalProject.Pages.Customer.CartModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="container py-4">
    <div class="section-header-glass">
        <h1 class="section-title-glass">Giỏ hàng</h1>
    </div>

    @if (Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="empty-state-glass">
            <i class="bi bi-cart-x empty-icon"></i>
            <p>Giỏ hàng trống. Hãy thêm sản phẩm bạn yêu thích!</p>
            <a href="/Customer/Products" class="btn-glass-primary" style="display:inline-flex;">
                <i class="bi bi-arrow-right"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="stagger-children">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="cart-item-glass">
                            @if (!string.IsNullOrEmpty(item.SanPham?.HinhAnhUrl))
                            {
                                <img src="@item.SanPham.HinhAnhUrl" class="cart-item-image-glass" alt="@item.SanPham.TenSanPham" onerror="fallbackImg(this)">
                            }
                            else
                            {
                                <div class="cart-item-image-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                            <div>
                                <p class="cart-item-title-glass">@item.SanPham?.TenSanPham</p>
                                <p class="cart-item-price-glass">@item.DonGia.ToString("N0")₫ / sản phẩm</p>
                                <div class="cart-item-actions-glass">
                                    <form method="post" asp-page="/Customer/Cart" asp-page-handler="UpdateQuantity" asp-route-cartItemId="@item.Id" style="display:flex;align-items:center;gap:0.4rem;">
                                        <button type="submit" name="quantity" value="@(item.SoLuong - 1)" class="qty-btn-glass" @(item.SoLuong <= 1 ? "disabled" : "")>
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="qty-value-glass">@item.SoLuong</span>
                                        <button type="submit" name="quantity" value="@(item.SoLuong + 1)" class="qty-btn-glass">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="cart-item-total-glass">
                                <p class="total-price">@((item.SoLuong * item.DonGia).ToString("N0"))₫</p>
                                <form method="post" asp-page="/Customer/Cart" asp-page-handler="Remove" asp-route-cartItemId="@item.Id">
                                    <button type="submit" class="remove-btn">
                                        <i class="bi bi-trash3"></i> Xoá
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4">
                <div class="cart-summary-glass animate-scale-in">
                    <h3>Tổng giỏ hàng</h3>
                    <div class="summary-row">
                        <span style="color:var(--text-secondary);">Tạm tính:</span>
                        <strong>@Model.Total.ToString("N0")₫</strong>
                    </div>
                    <div class="summary-row">
                        <span style="color:var(--text-secondary);">Phí vận chuyển:</span>
                        <strong>Miễn phí</strong>
                    </div>
                    <div class="summary-row total">
                        <span>Tổng cộng:</span>
                        <span>@Model.Total.ToString("N0")₫</span>
                    </div>
                    <a href="/Customer/Checkout" class="btn-glass-primary" style="display:flex;justify-content:center;width:100%;margin-top:1.25rem;">
                        <i class="bi bi-credit-card"></i> Thanh toán
                    </a>
                    <a href="/Customer/Products" class="btn-glass-secondary" style="display:flex;justify-content:center;width:100%;margin-top:0.65rem;">
                        <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    }
</section>
