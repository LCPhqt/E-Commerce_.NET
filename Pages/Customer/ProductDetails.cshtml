@page
@model ECommerceFinalProject.Pages.Customer.ProductDetailsModel
@{
    ViewData["Title"] = Model.Product?.TenSanPham ?? "Chi tiết sản phẩm";
}

<section class="container py-4">
@if (Model.Product == null)
{
    <div class="empty-state-glass">
        <i class="bi bi-exclamation-triangle empty-icon"></i>
        <p>Sản phẩm không tồn tại.</p>
        <a href="/Customer/Products" class="btn-glass-primary" style="display:inline-flex;">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb-glass">
            <li><a href="/Customer/Home"><i class="bi bi-house-door"></i> Trang chủ</a></li>
            <li><a href="/Customer/Products">Sản phẩm</a></li>
            @if (Model.Product.DanhMuc != null)
            {
                <li><a href="/Customer/Products?categoryId=@Model.Product.DanhMucId">@Model.Product.DanhMuc.Ten</a></li>
            }
            <li class="active">@Model.Product.TenSanPham</li>
        </ol>
    </nav>

    <!-- Product Detail -->
    <div class="product-detail-glass">
        <div class="animate-scale-in">
            <div class="detail-image-wrap">
                @if (!string.IsNullOrEmpty(Model.Product.HinhAnhUrl))
                {
                    <img src="@Model.Product.HinhAnhUrl" class="detail-image" alt="@Model.Product.TenSanPham" onerror="fallbackImg(this)">
                }
                else
                {
                    <div style="min-height:400px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:4rem;">
                        <i class="bi bi-image"></i>
                    </div>
                }
            </div>
        </div>
        <div class="product-detail-info animate-fade-in-up">
            @if (Model.Product.DanhMuc != null)
            {
                <span class="detail-category">@Model.Product.DanhMuc.Ten</span>
            }
            <h1 class="detail-title">@Model.Product.TenSanPham</h1>
            <p class="detail-price">@Model.Product.Gia.ToString("N0")₫</p>

            <!-- Stock -->
            @if (Model.Product.SoLuongTon > 0)
            {
                <div class="stock-info-glass in-stock">
                    <i class="bi bi-check-circle-fill"></i> Còn hàng
                    <span style="color:var(--text-muted);font-weight:400;">(@Model.Product.SoLuongTon sản phẩm)</span>
                </div>
            }
            else
            {
                <div class="stock-info-glass out-of-stock">
                    <i class="bi bi-x-circle-fill"></i> Tạm hết hàng
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Product.MoTa))
            {
                <div class="detail-desc rich-content">
                    @Html.Raw(Model.Product.MoTa)
                </div>
            }

            <!-- Actions -->
            @if (User.Identity?.IsAuthenticated == true && Model.Product.SoLuongTon > 0)
            {
                <form method="post" asp-page="/Customer/Cart" asp-page-handler="Add" asp-route-productId="@Model.Product.Id">
                    <div class="d-flex gap-3 align-items-center mb-3">
                        <label style="font-family:var(--font-body);font-size:0.75rem;font-weight:550;letter-spacing:0.04em;text-transform:uppercase;color:var(--text-secondary);">Số lượng:</label>
                        <input type="number" name="quantity" value="1" min="1" max="@Model.Product.SoLuongTon" class="quantity-input-glass" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-glass-primary flex-grow-1">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                        </button>
                        <a href="/Customer/Checkout?buyNow=@Model.Product.Id" class="btn-glass-secondary">
                            <i class="bi bi-lightning-fill"></i> Mua ngay
                        </a>
                    </div>
                </form>
            }
            else if (User.Identity?.IsAuthenticated != true)
            {
                <a href="/Account/Login" class="btn-glass-primary" style="display:inline-flex;">
                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập để mua
                </a>
            }
            else
            {
                <div class="alert-glass error" style="display:flex;align-items:center;gap:0.5rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i> Sản phẩm này hiện đã hết hàng.
                </div>
            }
        </div>
    </div>

    <!-- Related Products -->
    @if (Model.RelatedProducts.Any())
    {
        <section class="mb-5 mt-5">
            <div class="section-header-glass">
                <h2 class="section-title-glass">Sản phẩm liên quan</h2>
            </div>
            <div class="row g-4 stagger-children">
                @foreach (var product in Model.RelatedProducts)
                {
                    <div class="col-6 col-md-3">
                        <div class="product-card-glass">
                            <div class="card-image-wrap">
                                @if (!string.IsNullOrEmpty(product.HinhAnhUrl))
                                {
                                    <img src="@product.HinhAnhUrl" class="card-img-top" alt="@product.TenSanPham" onerror="fallbackImg(this)">
                                }
                                else
                                {
                                    <div class="card-img-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </div>
                            <div class="card-body">
                                <p class="product-title">@product.TenSanPham</p>
                                <p class="product-price">@product.Gia.ToString("N0")₫</p>
                                <div class="product-footer">
                                    <a href="/Customer/ProductDetails?id=@product.Id" class="btn-view-glass w-100">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
}
</section>
