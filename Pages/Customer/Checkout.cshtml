@page
@model ECommerceFinalProject.Pages.Customer.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán";
}

<section class="container py-4">
    <div class="section-header-glass">
        <h1 class="section-title-glass">Thanh toán</h1>
    </div>

    @if (!Model.HasItems)
    {
        <div class="empty-state-glass">
            <i class="bi bi-cart-x empty-icon"></i>
            <p>Giỏ hàng trống. Vui lòng thêm sản phẩm trước khi thanh toán.</p>
            <a href="/Customer/Products" class="btn-glass-primary" style="display:inline-flex;">
                <i class="bi bi-arrow-right"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="checkout-section-glass animate-fade-in-up">
                    <h3><i class="bi bi-truck" style="margin-right:0.5rem;background:var(--accent-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i> Thông tin giao hàng</h3>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label-glass">
                                Địa chỉ giao hàng <span class="required">*</span>
                            </label>
                            <textarea name="DiaChiGiao" rows="3" class="form-input-glass" required placeholder="Nhập địa chỉ nhận hàng..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label-glass">
                                Ghi chú <span style="color:var(--text-muted);font-weight:400;text-transform:none;">(không bắt buộc)</span>
                            </label>
                            <textarea name="GhiChu" rows="2" class="form-input-glass" placeholder="Ghi chú cho đơn hàng..."></textarea>
                        </div>
                        <button type="submit" class="btn-glass-primary" style="width:100%;justify-content:center;">
                            <i class="bi bi-check-circle"></i> Xác nhận đặt hàng — @Model.Total.ToString("N0")₫
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="order-summary-glass animate-fade-in-up" style="animation-delay:0.1s;">
                    <h3><i class="bi bi-receipt" style="margin-right:0.5rem;background:var(--accent-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i> Đơn hàng của bạn</h3>
                    @if (Model.CartItems != null)
                    {
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="order-item-glass">
                                <div>
                                    <span class="item-name">@item.SanPham?.TenSanPham</span>
                                    <br>
                                    <span class="item-qty">Số lượng: @item.SoLuong</span>
                                </div>
                                <span class="item-total">@((item.SoLuong * item.DonGia).ToString("N0"))₫</span>
                            </div>
                            <hr class="order-divider">
                        }
                    }
                    <div class="order-total-glass">
                        <span class="total-label">Tổng cộng:</span>
                        <span class="total-amount">@Model.Total.ToString("N0")₫</span>
                    </div>
                </div>
            </div>
        </div>
    }
</section>
