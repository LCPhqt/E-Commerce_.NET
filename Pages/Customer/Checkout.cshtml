@page
@model ECommerceFinalProject.Pages.Customer.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán";
}

<section class="container py-4">
    <div class="section-header">
        <h1 class="section-title">Thanh toán</h1>
    </div>

    @if (!Model.HasItems)
    {
        <div class="text-center py-5" style="border:1px solid var(--border-light);border-radius:var(--radius-card);">
            <i class="bi bi-cart-x" style="font-size: 64px; color: var(--text-muted);"></i>
            <p class="text-secondary mt-3">Giỏ hàng trống. Vui lòng thêm sản phẩm trước khi thanh toán.</p>
            <a href="/Customer/Products" class="btn-editorial" style="display:inline-flex;">
                <i class="bi bi-arrow-right"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-7">
                <div style="background:var(--bg-card);border:1px solid var(--border-light);border-radius:var(--radius-card);padding:1.5rem;margin-bottom:1.5rem;">
                    <h3 style="font-family:var(--font-display);font-size:1.3rem;font-weight:600;margin-bottom:1.25rem;">Thông tin giao hàng</h3>
                    <form method="post">
                        <div class="mb-3">
                            <label style="font-family:var(--font-body);font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-secondary);margin-bottom:0.35rem;display:block;">
                                Địa chỉ giao hàng <span style="color:var(--accent);">*</span>
                            </label>
                            <textarea name="DiaChiGiao" rows="3" style="width:100%;font-family:var(--font-body);font-size:0.85rem;padding:0.65rem 0.85rem;border:1px solid var(--border-light);border-radius:var(--radius-btn);background:var(--bg-card);color:var(--text-primary);" required placeholder="Nhập địa chỉ nhận hàng..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label style="font-family:var(--font-body);font-size:0.75rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-secondary);margin-bottom:0.35rem;display:block;">
                                Ghi chú
                            </label>
                            <textarea name="GhiChu" rows="2" style="width:100%;font-family:var(--font-body);font-size:0.85rem;padding:0.65rem 0.85rem;border:1px solid var(--border-light);border-radius:var(--radius-btn);background:var(--bg-card);color:var(--text-primary);" placeholder="Ghi chú cho đơn hàng (không bắt buộc)..."></textarea>
                        </div>
                        <button type="submit" class="btn-editorial-primary" style="width:100%;justify-content:center;">
                            <i class="bi bi-check-circle"></i> Xác nhận đặt hàng — @Model.Total.ToString("N0")₫
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-lg-5">
                <div style="background:var(--bg-card);border:1px solid var(--border-light);border-radius:var(--radius-card);padding:1.5rem;">
                    <h3 style="font-family:var(--font-display);font-size:1.3rem;font-weight:600;margin-bottom:1.25rem;">Đơn hàng của bạn</h3>
                    @if (Model.CartItems != null)
                    {
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2" style="font-size:0.9rem;">
                                <div>
                                    <span style="font-weight:500;">@item.SanPham?.TenSanPham</span>
                                    <br>
                                    <span style="color:var(--text-muted);font-size:0.8rem;">Số lượng: @item.SoLuong</span>
                                </div>
                                <strong style="color:var(--accent);">@((item.SoLuong * item.DonGia).ToString("N0"))₫</strong>
                            </div>
                            <hr style="border-color:var(--border-light);margin:0.5rem 0;">
                        }
                    }
                    <div class="d-flex justify-content-between" style="font-size:1.1rem;margin-top:0.75rem;">
                        <span style="font-weight:600;">Tổng cộng:</span>
                        <strong style="color:var(--accent);">@Model.Total.ToString("N0")₫</strong>
                    </div>
                </div>
            </div>
        </div>
    }
</section>
