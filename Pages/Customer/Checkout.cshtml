@page
@model ECommerceFinalProject.Pages.Customer.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán";
}

<h3 class="fw-bold mb-4"><i class="bi bi-credit-card"></i> Thanh toán</h3>

@if (!Model.HasItems)
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size: 64px; color: #ccc;"></i>
        <p class="text-muted mt-3">Giỏ hàng trống. Vui lòng thêm sản phẩm trước khi thanh toán.</p>
        <a href="/Customer/Products" class="btn btn-primary">Mua sắm ngay</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Thông tin giao hàng</h5>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <textarea name="DiaChiGiao" class="form-control" rows="3" required placeholder="Nhập địa chỉ nhận hàng..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ghi chú</label>
                            <textarea name="GhiChu" class="form-control" rows="2" placeholder="Ghi chú cho đơn hàng (không bắt buộc)..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-check-circle"></i> Xác nhận đặt hàng (@Model.Total.ToString("N0")đ)
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Đơn hàng của bạn</h5>
                    @if (Model.CartItems != null)
                    {
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <small class="fw-bold">@item.SanPham?.TenSanPham</small>
                                    <br>
                                    <small class="text-muted">Số lượng: @item.SoLuong</small>
                                </div>
                                <strong>@((item.SoLuong * item.DonGia).ToString("N0"))đ</strong>
                            </div>
                            <hr class="my-2">
                        }
                    }
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">Tổng cộng:</span>
                        <strong class="text-danger fs-5">@Model.Total.ToString("N0")đ</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
