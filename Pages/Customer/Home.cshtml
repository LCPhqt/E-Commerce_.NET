@page
@model ECommerceFinalProject.Pages.Customer.HomeModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="hero-section text-center">
    <h1><i class="bi bi-shop"></i> Chào mừng đến với ECommerce</h1>
    <p class="lead mb-4">Khám phá hàng ngàn sản phẩm với giá ưu đãi</p>
    <a href="/Customer/Products" class="btn btn-light btn-lg px-5">
        <i class="bi bi-bag"></i> Mua sắm ngay
    </a>
</div>

@if (Model.NewProducts.Any())
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold"><i class="bi bi-star"></i> Sản phẩm mới nhất</h3>
            <a href="/Customer/Products" class="btn btn-outline-primary">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-4">
            @foreach (var product in Model.NewProducts)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card shadow-sm">
                        @if (!string.IsNullOrEmpty(product.HinhAnhUrl))
                        {
                            <img src="@product.HinhAnhUrl" class="card-img-top" alt="@product.TenSanPham" onerror="fallbackImg(this)">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-muted">
                                <i class="bi bi-image" style="font-size: 48px;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <p class="product-title">@product.TenSanPham</p>
                            <p class="product-price">@product.Gia.ToString("N0")đ</p>
                            <a href="/Customer/ProductDetails?id=@product.Id" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-eye"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}
