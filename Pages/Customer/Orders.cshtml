@page
@model ECommerceFinalProject.Pages.Customer.OrdersModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<section class="container py-4">
    <div class="section-header-glass">
        <h1 class="section-title-glass">Đơn hàng của tôi</h1>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="empty-state-glass">
            <i class="bi bi-inbox empty-icon"></i>
            <p>Bạn chưa có đơn hàng nào.</p>
            <a href="/Customer/Products" class="btn-glass-primary" style="display:inline-flex;">
                <i class="bi bi-arrow-right"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="stagger-children">
            @foreach (var order in Model.Orders)
            {
                <div class="order-card-glass">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="order-id">Đơn hàng #@order.Id</p>
                            <span class="order-date">@order.NgayDat.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <span class="status-badge-glass
                            @(order.TrangThai == "Chờ xử lý" ? "status-pending" :
                              order.TrangThai == "Đang giao" ? "status-shipping" :
                              order.TrangThai == "Đã giao" ? "status-delivered" :
                              "status-cancelled")">
                            @order.TrangThai
                        </span>
                    </div>

                    @if (order.OrderDetails != null)
                    {
                        @foreach (var detail in order.OrderDetails)
                        {
                            <div class="d-flex justify-content-between align-items-center py-1" style="font-size:0.9rem;">
                                <span>@detail.TenSanPham <span style="color:var(--text-muted);">x@(detail.SoLuong)</span></span>
                                <span style="font-weight:500;">@((detail.SoLuong * detail.DonGia).ToString("N0"))₫</span>
                            </div>
                        }
                    }

                    <hr style="border-color:var(--border-light);margin:0.75rem 0;">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2" style="font-size:0.9rem;">
                        <span style="color:var(--text-secondary);"><strong style="color:var(--text-primary);">Địa chỉ:</strong> @order.DiaChiGiao</span>
                        <strong class="order-total">Tổng: @order.TongTien.ToString("N0")₫</strong>
                    </div>
                    @if (!string.IsNullOrEmpty(order.GhiChu))
                    {
                        <div class="mt-2" style="color:var(--text-muted);font-size:0.85rem;padding:0.5rem 0.75rem;background:var(--bg-glass-dark);border-radius:var(--radius-sm);">
                            <strong>Ghi chú:</strong> @order.GhiChu
                        </div>
                    }

                    @if (order.TrangThai == "Chờ xử lý")
                    {
                        <div class="mt-3">
                            <form method="post" asp-page-handler="Cancel" onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng #@order.Id?');">
                                <input type="hidden" name="orderId" value="@order.Id" />
                                <button type="submit" class="btn-glass-danger">
                                    <i class="bi bi-x-circle"></i> Hủy đơn hàng
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    }
</section>
